# Directories that Ren'Py changes files in.
/game/saves
/game/cache

# Compiled script files. These are important for saving, and so should
# be preserved by developer and build systems after the game has been released.
/game/**/*.rpyc
/game/**/*.rpymc

# Files Ren'Py can generate.
/game/**/*.bak
/game/**/*.new
/game/**/*.old

# Error, log, and output files.
/development_log.txt
/errors.txt
/files.txt
/image_cache.txt
/log.txt
/save_dump.txt
/traceback.txt
/http_log.txt
/llm_log.txt
/project.json
/android.json
/android.keystore
/bundle.keystore

# Launcher-generated files.
/dialogue.tab
/dialogue.txt
/strings.json

# Python cache
__pycache__/
*.pyc
*.pyo

# VSCode settings
.vscode/

# OS-specific clutter
.DS_Store
Thumbs.db

